{
  "permissions": {
    "allow": [
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(databricks apps *)",
      "Bash(databricks bundle *)",
      "Bash(databricks workspace *)",
      "Bash(databricks api *)",
      "Bash(databricks current-user *)",
      "Bash(git *)",
      "Bash(ruff *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(rm -rf /tmp/*)",
      "Bash(sleep *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(curl *)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf /*)",
      "Bash(npm publish *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"${CLAUDE_FILE_PATH}\" | grep -qE '\\.(js|jsx|ts|tsx)$' && npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "echo \"${CLAUDE_FILE_PATH}\" | grep -qE '\\.(js|jsx|ts|tsx)$' && npx eslint --fix \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "[ \"${CLAUDE_FILE_PATH##*.}\" = \"py\" ] && ruff format \"$CLAUDE_FILE_PATH\" || true"
          },
          {
            "type": "command",
            "command": "[ \"${CLAUDE_FILE_PATH##*.}\" = \"py\" ] && ruff check --fix \"$CLAUDE_FILE_PATH\" || true"
          }
        ]
      }
    ]
  }
}

{
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(git *)",
      "Bash(ruff *)",
      "Bash(mlflow *)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(pip uninstall *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"${CLAUDE_FILE_PATH##*.}\" = \"py\" ] && ruff format \"$CLAUDE_FILE_PATH\" || true"
          },
          {
            "type": "command",
            "command": "[ \"${CLAUDE_FILE_PATH##*.}\" = \"py\" ] && ruff check --fix \"$CLAUDE_FILE_PATH\" || true"
          }
        ]
      }
    ]
  }
}

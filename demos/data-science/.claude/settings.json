{
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(git *)",
      "Bash(ruff *)",
      "Bash(mlflow *)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(pip uninstall *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ruff format $FILEPATH"
          },
          {
            "type": "command",
            "command": "ruff check --fix $FILEPATH"
          }
        ]
      }
    ]
  }
}
